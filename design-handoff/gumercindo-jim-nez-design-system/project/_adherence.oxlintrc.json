{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/editorial/**",
              "components/feedback/**",
              "components/forms/**",
              "ui_kits/book/**",
              "ui_kits/website/**",
              "ui_kits/workbook/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Cormorant Garamond|Spectral|Hanken Grotesk))/i]",
        "message": "Font not provided by the design system. Available: Cormorant Garamond, Spectral, Hanken Grotesk."
      },
      {
        "selector": "JSXOpeningElement[name.name='AccordionItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:q|a|key|ref|className|style|children)$/]",
        "message": "<AccordionItem> doesn't accept that prop. Declared props: q, a."
      },
      {
        "selector": "JSXOpeningElement[name.name='BlockLabel'] > JSXAttribute > JSXIdentifier[name!=/^(?:glyph|children|rule|style|key|ref|className|style|children)$/]",
        "message": "<BlockLabel> doesn't accept that prop. Declared props: glyph, children, rule, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|iconLeft|iconRight|fullWidth|disabled|type|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, iconLeft, iconRight, fullWidth, disabled, type, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:solid|accent|outline|ghost|link)$/]",
        "message": "<Button> variant must be one of 'solid' | 'accent' | 'outline' | 'ghost' | 'link'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|interactive|padding|accentRule|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, tone, interactive, padding, accentRule, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:paper|sunken|tint|dark)$/]",
        "message": "<Card> tone must be one of 'paper' | 'sunken' | 'tint' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='padding'] > Literal[value!=/^(?:none|sm|md|lg|xl)$/]",
        "message": "<Card> padding must be one of 'none' | 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|rule|tone|style|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: children, rule, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:accent|brand|metal|muted|onDark)$/]",
        "message": "<Eyebrow> tone must be one of 'accent' | 'brand' | 'metal' | 'muted' | 'onDark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|value|onChange|placeholder|type|required|disabled|adornment|id|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, error, value, onChange, placeholder, type, required, disabled, adornment, id, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|tone|height|base|style|key|ref|className|style|children)$/]",
        "message": "<Logo> doesn't accept that prop. Declared props: variant, tone, height, base, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:symbol|lockup)$/]",
        "message": "<Logo> variant must be one of 'symbol' | 'lockup'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:auto|light|dark|onDark|gold)$/]",
        "message": "<Logo> tone must be one of 'auto' | 'light' | 'dark' | 'onDark' | 'gold'."
      },
      {
        "selector": "JSXOpeningElement[name.name='QuoteBlock'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|author|style|key|ref|className|style|children)$/]",
        "message": "<QuoteBlock> doesn't accept that prop. Declared props: children, author, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='RatingScale'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|max|style|key|ref|className|style|children)$/]",
        "message": "<RatingScale> doesn't accept that prop. Declared props: label, hint, max, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|prefix|suffix|tone|align|style|key|ref|className|style|children)$/]",
        "message": "<Stat> doesn't accept that prop. Declared props: value, label, prefix, suffix, tone, align, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:default|dark)$/]",
        "message": "<Stat> tone must be one of 'default' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:start|center)$/]",
        "message": "<Stat> align must be one of 'start' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|tone|style|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, variant, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:soft|solid|outline)$/]",
        "message": "<Tag> variant must be one of 'soft' | 'solid' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:brand|clay|gold|neutral)$/]",
        "message": "<Tag> tone must be one of 'brand' | 'clay' | 'gold' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Testimonial'] > JSXAttribute > JSXIdentifier[name!=/^(?:quote|author|role|tone|size|style|key|ref|className|style|children)$/]",
        "message": "<Testimonial> doesn't accept that prop. Declared props: quote, author, role, tone, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Testimonial'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:paper|dark)$/]",
        "message": "<Testimonial> tone must be one of 'paper' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Testimonial'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Testimonial> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='WorksheetPrompt'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|number|example|lines|style|key|ref|className|style|children)$/]",
        "message": "<WorksheetPrompt> doesn't accept that prop. Declared props: children, variant, number, example, lines, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='WorksheetPrompt'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:card|plain)$/]",
        "message": "<WorksheetPrompt> variant must be one of 'card' | 'plain'."
      },
      {
        "selector": "JSXOpeningElement[name.name='WritingLines'] > JSXAttribute > JSXIdentifier[name!=/^(?:count|gap|style|key|ref|className|style|children)$/]",
        "message": "<WritingLines> doesn't accept that prop. Declared props: count, gap, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
